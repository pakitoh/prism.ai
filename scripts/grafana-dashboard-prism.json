{
  "uid": "prism-investigations",
  "title": "prism.ai — Investigations",
  "tags": ["prism", "investigations"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Investigations by outcome (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (outcome) (rate(prism_investigation_duration_milliseconds_count[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 time-to-conclusion",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(prism_investigation_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tool-call distribution",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "values": ["value"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (step_kind) (increase(prism_reasoning_step_duration_milliseconds_count[$__range]))",
          "legendFormat": "{{step_kind}}",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Confidence mix (concluded)",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "values": ["value"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (confidence) (increase(prism_investigation_concluded_total[$__range]))",
          "legendFormat": "{{confidence}}",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Token usage by model (per-sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (model, token_type) (rate(prism_reasoning_tokens_sum[5m]))",
          "legendFormat": "{{model}} / {{token_type}}"
        }
      ]
    }
  ]
}
