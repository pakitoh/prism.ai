# Build output (rebuilt inside the image)
**/target/

# Local container data + decompiled-jar debris — not sources
data/
com/
org/

# VCS, IDE, env, logs
# .git is intentionally NOT excluded: the git-commit-id plugin reads it during the
# image build to stamp the commit into git.properties (logged at startup).
.idea/
.vscode/
.env
.logs/
*.iml

# Docs / assets not needed to build the service
*.md
media/

# The Dockerfile context itself
Dockerfile
.dockerignore
